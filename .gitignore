venv/
**/venv/
.venv/
**/.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Testing
coverage/
**/coverage/

# Next.js
.next/
**/.next/
out/
**/out/

# Production builds and caches
build/
**/build/
dist/
**/dist/
.cache/
**/.cache/
*.tsbuildinfo
next-env.d.ts

